# Streamlit Cloud secrets — copy this to .streamlit/secrets.toml
# and add your real keys. Do NOT commit secrets.toml to git.

ANTHROPIC_API_KEY       = "your_anthropic_api_key_here"
NEWS_API_KEY            = "your_newsapi_key_here"
STOCKTWITS_ACCESS_TOKEN = "your_stocktwits_access_token_here"
# Register free at https://api.stocktwits.com/developers/apps/new
