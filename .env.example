# ── Required for AI Briefing ────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required for News Sentiment ─────────────────────────────────────────────
# Free tier at https://newsapi.org (100 requests/day)
NEWS_API_KEY=your_newsapi_key_here

# ── Required for Reddit Sentiment ───────────────────────────────────────────
# Create a Reddit app at https://www.reddit.com/prefs/apps
# Choose "script" type — no callback URL needed for read-only access
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# ── X/Twitter (OPTIONAL — paid tier required) ───────────────────────────────
# X API Basic tier is $100/month. StockTwits is a free alternative.
# TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
