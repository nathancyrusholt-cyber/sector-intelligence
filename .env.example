# ── Required for AI Briefing ────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Required for News Sentiment ─────────────────────────────────────────────
# Free tier at https://newsapi.org (100 requests/day)
NEWS_API_KEY=your_newsapi_key_here

# ── StockTwits (free access token required) ──────────────────────────────────
# StockTwits API requires a free access token even for public read-only streams.
# Register at https://api.stocktwits.com/developers/apps/new (free, instant)
STOCKTWITS_ACCESS_TOKEN=your_stocktwits_access_token_here
